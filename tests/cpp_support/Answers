  public:
    int x;
    void set(int val) {
      this->x = val;
    }
    int get() {
      return this->x;
    }

    virtual int num() {
      return 1;
    }
};
class B : public A {
  public:
    int y;
    int num() override {
      return 2;
    }
};


class C {
  public:
    int x;
    C(int val) {
      this->x = val;
    }

    ~C() {}
};

class Unused {
};

int main() {
  class A a;
  a.A::set(1);
  a.A::get();

  class B b;
  class A *a_ptr = &b;

  a_ptr->num(); // Should not be qualified as it is dynamically dispatched
  b.num(); // Should not be qualified, still goes via vtable

  class C c(10);

  c.C::~C();

  return 0;
}
