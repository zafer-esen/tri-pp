--- throw_with_cast.cpp ---
class MyException {};

void f() {
  // Existing elaborated cast
  throw (class MyException) (class MyException) MyException();
}

void g() {
  // Existing unelaborated cast
  throw (class MyException) (MyException) MyException();
}

struct S { int a; };

void h() {
  // Existing struct cast
  throw (struct S) (struct S) S{1};
}

int main() {
  try { f(); } catch (...) {}
  try { g(); } catch (...) {}
  try { h(); } catch (...) {}
  return 0;
}
